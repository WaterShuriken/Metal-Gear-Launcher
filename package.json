{
  "name": "metal-gear-launcher",
  "version": "1.0.1",
  "description": "A launcher for the Metal Gear Series of games",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "author": "Allison",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.1.7",
    "fs-extra": "^11.3.4"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.allie.mgslauncher",
    "productName": "metal-gear-launcher",
    "directories": {
      "output": "dist"
    },
    "win": {
      "publish": ["github"],
      "icon": "img/icon.ico",
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "img/icon.ico",
      "uninstallerIcon": "img/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "WaterShuriken",
        "repo": "Metal-Gear-Launcher"
      }
    ],
    "files": [
      "**/*",
      "!emulators${/*}",
      "!roms${/*}",
      "!shortcuts${/*}",
      "!.vscode${/*}",
      "!.git${/*}",
      "!installer_scripts${/*}",
      "!update.key",
      "!Output${/*}",
      "!dist${/*}"
    ]
  }
}
